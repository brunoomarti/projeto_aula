#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Java heap dumps (Gradle OOM — podem ter vários GB)
*.hprof

# Caches e artefatos pesados Android/Gradle
android/.gradle/
android/.kotlin/
**/.kotlin/
android/**/build/
android/captures/

# Binários de build locais
*.apk
*.aab
*.ipa

# iOS build local
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/build/
**/DerivedData/
