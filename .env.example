# Copie este arquivo para `.env` na raiz do projeto e preencha a chave.
# O arquivo `.env` não é versionado no Git.
#
# APIs a habilitar na chave (Google Cloud Console → Biblioteca):
#   • Places API (New)  — autocomplete + detalhes de lugares (criação/edição)
#   • Geocoding API     — endereço legível nos cards (reverse geocode)
GOOGLE_PLACES_API_KEY=

# Gemini — parser híbrido do magic input (opcional; ver MagicInputParserConfig).
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
