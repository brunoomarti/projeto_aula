<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template — NÃO use estes valores em produção.
  1. Firebase Console → Adicionar app iOS (bundle: com.tasker.project)
  2. Baixe GoogleService-Info.plist e coloque em ios/Runner/
  3. Ou execute: flutterfire configure
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_ME.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.REPLACE_ME</string>
	<key>API_KEY</key>
	<string>REPLACE_ME</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_ME</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.tasker.project</string>
	<key>PROJECT_ID</key>
	<string>tasker-196a2</string>
	<key>STORAGE_BUCKET</key>
	<string>tasker-196a2.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:REPLACE_ME:ios:REPLACE_ME</string>
</dict>
</plist>
